# MongoDB connection string
# Sign up at mongodb.com/atlas for free tier (512MB free)
# Create a cluster, get your connection string, paste here
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/skipschool?retryWrites=true&w=majority

# Payload secret - generate a random string (min 32 chars)
# You can use: openssl rand -hex 32
PAYLOAD_SECRET=CHANGE_ME_TO_A_RANDOM_STRING_AT_LEAST_32_CHARS

# Site URL (change to https://skipschool.ai in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Beehiiv API (for newsletter signup integration)
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=
